# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=shahgrid
POSTGRES_USER=shahgrid
POSTGRES_PASSWORD=change_this_strong_password

# ── JWT Secrets (generate with: openssl rand -base64 64) ──────────────────────
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://your-server-ip/api/v1/auth/google/callback
FRONTEND_URL=http://your-server-ip

# ── Frontend ───────────────────────────────────────────────────────────────────
# Used at Flutter build time: flutter build web --dart-define=API_BASE_URL=...
API_BASE_URL=http://your-server-ip/api/v1

# ── Nginx Settings ───────────────────────────────────────────────────────────────
DOMAIN=app.example.com