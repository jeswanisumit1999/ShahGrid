generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (pgBouncer, transaction mode) used by the app at runtime.
  url       = env("DATABASE_URL")
  // Direct Postgres connection used for `prisma migrate` / introspection,
  // which cannot run through a transaction-mode pooler.
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─────────────────────────────────────────────
// IDENTITY DOMAIN
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(uuid()) @db.Uuid
  googleId  String   @unique @map("google_id") @db.VarChar(128)
  email     String   @unique @db.VarChar(255)
  name      String   @db.VarChar(255)
  avatarUrl String?  @map("avatar_url") @db.VarChar(512)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  userRoles              UserRole[]              @relation("UserRoleUser")
  assignedRoles          UserRole[]              @relation("UserRoleAssignedBy")
  createdOrders          Order[]                 @relation("OrderCreatedBy")
  salesOfficerOrders     Order[]                 @relation("OrderSalesOfficer")
  assignedRetailers      RetailerSalesOfficer[]
  stockAdjustments       StockAdjustment[]
  visitLogs              VisitLog[]
  checkIns               CheckIn[]
  updatedSettings        AppSetting[]
  deviceTokens           DeviceToken[]
  directSalesCreated     DirectSale[]            @relation("DirectSaleCreatedBy")
  directSalesAsSO        DirectSale[]            @relation("DirectSaleSalesOfficer")

  @@map("users")
}

model Role {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique @db.VarChar(64)
  description  String?  @db.VarChar(255)
  isSystemRole Boolean  @default(false) @map("is_system_role")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id       String @id @default(uuid()) @db.Uuid
  resource String @db.VarChar(64)
  action   String @db.VarChar(64)

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedBy String   @map("assigned_by") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz

  user           User @relation("UserRoleUser", fields: [userId], references: [id])
  role           Role @relation(fields: [roleId], references: [id])
  assignedByUser User @relation("UserRoleAssignedBy", fields: [assignedBy], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model DeviceToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(512)
  platform  String   @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("device_tokens")
}

// ─────────────────────────────────────────────
// RETAILER DOMAIN
// ─────────────────────────────────────────────

model Retailer {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String   @db.VarChar(255)
  phone                 String   @unique @db.VarChar(20)
  address               String?  @db.VarChar(512)
  gstin                 String?  @db.VarChar(15)
  creditLimit           Decimal  @default(0) @map("credit_limit") @db.Decimal(12, 2)
  pendingCollection     Decimal  @default(0) @map("pending_collection") @db.Decimal(12, 2)
  isDirectSale          Boolean  @default(false) @map("is_direct_sale")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  salesOfficers   RetailerSalesOfficer[]
  orders          Order[]
  payments        Payment[]
  returns         Return[]
  visitLogs       VisitLog[]
  companyBalances RetailerCompanyBalance[]
  retailerLedger  RetailerLedger[]

  @@map("retailers")
}

model RetailerCompanyBalance {
  retailerId    String  @map("retailer_id") @db.Uuid
  companyId     String  @map("company_id") @db.Uuid
  pendingAmount Decimal @default(0) @map("pending_amount") @db.Decimal(12, 2)

  retailer Retailer @relation(fields: [retailerId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])

  @@id([retailerId, companyId])
  @@map("retailer_company_balances")
}

model RetailerLedger {
  id            String   @id @default(uuid()) @db.Uuid
  retailerId    String   @map("retailer_id") @db.Uuid
  companyId     String?  @map("company_id") @db.Uuid
  delta         Decimal  @db.Decimal(12, 2)
  balanceAfter  Decimal  @map("balance_after") @db.Decimal(12, 2)
  type          String   @db.VarChar(40)
  referenceType String?  @map("reference_type") @db.VarChar(32)
  referenceId   String?  @map("reference_id") @db.VarChar(64)
  notes         String?  @db.VarChar(512)
  actorId       String?  @map("actor_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  retailer Retailer @relation(fields: [retailerId], references: [id])

  @@index([retailerId, createdAt(sort: Desc)])
  @@map("retailer_ledger")
}

model RetailerSalesOfficer {
  retailerId     String   @map("retailer_id") @db.Uuid
  salesOfficerId String   @map("sales_officer_id") @db.Uuid
  assignedAt     DateTime @default(now()) @map("assigned_at") @db.Timestamptz

  retailer     Retailer @relation(fields: [retailerId], references: [id])
  salesOfficer User     @relation(fields: [salesOfficerId], references: [id])

  @@id([retailerId, salesOfficerId])
  @@map("retailer_sales_officers")
}

// ─────────────────────────────────────────────
// CATALOG DOMAIN
// ─────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(255)
  gstin     String?  @db.VarChar(15)
  phone     String?  @db.VarChar(20)
  address   String?  @db.VarChar(512)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  products        Product[]
  shipments       Shipment[]
  overrideOrders  Order[]                  @relation("OrderOverrideCompany")
  retailerBalances RetailerCompanyBalance[]
  payments        Payment[]

  @@map("companies")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(128)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  products Product[]

  @@map("categories")
}

model Product {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  categoryId    String?  @map("category_id") @db.Uuid
  name          String   @db.VarChar(255)
  sku           String?  @db.VarChar(64)
  brand         String?  @db.VarChar(128)
  price         Decimal  @db.Decimal(10, 2)
  // DB CHECK constraint enforces non-negative: CHECK (stock_quantity >= 0)
  stockQuantity      Int      @default(0) @map("stock_quantity")
  lowStockThreshold  Int?     @map("low_stock_threshold")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  company          Company          @relation(fields: [companyId], references: [id])
  category         Category?        @relation(fields: [categoryId], references: [id])
  orderItems       OrderItem[]
  stockAdjustments StockAdjustment[]
  stockLedger      StockLedger[]
  directSaleItems  DirectSaleItem[]

  @@map("products")
}

// ─────────────────────────────────────────────
// ORDERS DOMAIN
// ─────────────────────────────────────────────

model Order {
  id               String   @id @default(uuid()) @db.Uuid
  retailerId       String   @map("retailer_id") @db.Uuid
  createdById      String   @map("created_by_id") @db.Uuid
  salesOfficerId   String   @map("sales_officer_id") @db.Uuid
  // Snapshot: if retailer was direct-sale at order time
  isDirectSale     Boolean  @default(false) @map("is_direct_sale")
  // Populated when sales officer overrides the assigned company
  overrideCompanyId String? @map("override_company_id") @db.Uuid
  totalAmount      Decimal  @db.Decimal(12, 2) @map("total_amount")
  challanNumber    String?  @map("challan_number") @db.VarChar(16)
  notes            String?  @db.VarChar(1024)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  retailer        Retailer  @relation(fields: [retailerId], references: [id])
  createdBy       User      @relation("OrderCreatedBy", fields: [createdById], references: [id])
  salesOfficer    User      @relation("OrderSalesOfficer", fields: [salesOfficerId], references: [id])
  overrideCompany Company?  @relation("OrderOverrideCompany", fields: [overrideCompanyId], references: [id])
  orderItems      OrderItem[]
  shipments       Shipment[]
  payments        Payment[]
  returns         Return[]

  @@map("orders")
}

model OrderItem {
  id                String  @id @default(uuid()) @db.Uuid
  orderId           String  @map("order_id") @db.Uuid
  productId         String  @map("product_id") @db.Uuid
  quantity          Int
  unitPrice         Decimal @db.Decimal(10, 2) @map("unit_price")
  // Tracks how much has been delivered across all shipments
  deliveredQuantity Int?    @map("delivered_quantity")

  order        Order        @relation(fields: [orderId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  shipmentItems ShipmentItem[]
  returnItems  ReturnItem[]

  @@map("order_items")
}

// ─────────────────────────────────────────────
// SHIPMENTS DOMAIN
// ─────────────────────────────────────────────

model Shipment {
  id           String    @id @default(uuid()) @db.Uuid
  orderId      String    @map("order_id") @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  // Status is managed via state machine in service layer — never updated directly
  status        String    @default("Pending Stock Verification") @db.VarChar(40)
  challanNumber String?   @map("challan_number") @db.VarChar(16)
  readyAt       DateTime? @map("ready_at") @db.Timestamptz
  deliveredAt  DateTime? @map("delivered_at") @db.Timestamptz
  returnedAt   DateTime? @map("returned_at") @db.Timestamptz
  notes        String?   @db.VarChar(1024)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  order         Order          @relation(fields: [orderId], references: [id])
  company       Company        @relation(fields: [companyId], references: [id])
  shipmentItems ShipmentItem[]

  @@map("shipments")
}

model ShipmentItem {
  id          String @id @default(uuid()) @db.Uuid
  shipmentId  String @map("shipment_id") @db.Uuid
  orderItemId String @map("order_item_id") @db.Uuid
  quantity    Int
  status      String @default("pending") @db.VarChar(32)

  shipment  Shipment  @relation(fields: [shipmentId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@map("shipment_items")
}

// ─────────────────────────────────────────────
// FINANCIALS DOMAIN
// ─────────────────────────────────────────────

model Payment {
  id             String   @id @default(uuid()) @db.Uuid
  orderId        String?  @map("order_id") @db.Uuid
  retailerId     String   @map("retailer_id") @db.Uuid
  companyId      String?  @map("company_id") @db.Uuid
  amount         Decimal  @db.Decimal(12, 2)
  paymentDate    DateTime @map("payment_date") @db.Date
  method         String   @db.VarChar(32)
  referenceNo    String?  @map("reference_no") @db.VarChar(128)
  // Prevents duplicate payment submissions from mobile clients
  idempotencyKey String?  @unique @map("idempotency_key") @db.VarChar(128)
  notes          String?  @db.VarChar(512)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  order    Order?   @relation(fields: [orderId], references: [id])
  retailer Retailer @relation(fields: [retailerId], references: [id])
  company  Company? @relation(fields: [companyId], references: [id])

  @@map("payments")
}

model Return {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  retailerId  String   @map("retailer_id") @db.Uuid
  returnValue Decimal  @map("return_value") @db.Decimal(12, 2)
  reason      String?  @db.VarChar(512)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  order       Order        @relation(fields: [orderId], references: [id])
  retailer    Retailer     @relation(fields: [retailerId], references: [id])
  returnItems ReturnItem[]

  @@map("returns")
}

model ReturnItem {
  id          String @id @default(uuid()) @db.Uuid
  returnId    String @map("return_id") @db.Uuid
  orderItemId String @map("order_item_id") @db.Uuid
  quantity    Int

  return    Return    @relation(fields: [returnId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@map("return_items")
}

// ─────────────────────────────────────────────
// OPERATIONS DOMAIN
// ─────────────────────────────────────────────

// Append-only passbook of every stock movement for a product.
// actorId / referenceId are loose (no FK) so records survive soft-deletes.
model StockLedger {
  id            String   @id @default(uuid()) @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  delta         Int
  balanceAfter  Int      @map("balance_after")
  // movement type: manual_in | manual_out | dispatch_out | dispatch_cancel_in
  //   | delivery_short_in | shipment_return_in | direct_sale_out | order_return_in
  type          String   @db.VarChar(40)
  referenceType String?  @map("reference_type") @db.VarChar(32)
  referenceId   String?  @map("reference_id") @db.VarChar(64)
  notes         String?  @db.VarChar(512)
  actorId       String?  @map("actor_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id])

  @@index([productId, createdAt(sort: Desc)])
  @@map("stock_ledger")
}

model StockAdjustment {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  adjustedBy  String   @map("adjusted_by") @db.Uuid
  delta       Int
  stockBefore Int      @map("stock_before")
  stockAfter  Int      @map("stock_after")
  reason      String?  @db.VarChar(512)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  product    Product @relation(fields: [productId], references: [id])
  adjustedByUser User @relation(fields: [adjustedBy], references: [id])

  @@map("stock_adjustments")
}

model VisitLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  retailerId String   @map("retailer_id") @db.Uuid
  latitude   Decimal  @db.Decimal(10, 7)
  longitude  Decimal  @db.Decimal(10, 7)
  notes      String?  @db.VarChar(512)
  visitedAt  DateTime @default(now()) @map("visited_at") @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id])
  retailer Retailer @relation(fields: [retailerId], references: [id])

  @@map("visit_logs")
}

model CheckIn {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  latitude    Decimal  @db.Decimal(10, 7)
  longitude   Decimal  @db.Decimal(10, 7)
  notes       String?  @db.VarChar(512)
  checkedInAt DateTime @default(now()) @map("checked_in_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("check_ins")
}

// ─────────────────────────────────────────────
// DIRECT SALES DOMAIN
// ─────────────────────────────────────────────

model DirectSale {
  id             String   @id @default(uuid()) @db.Uuid
  customerName   String   @map("customer_name") @db.VarChar(255)
  salesOfficerId String   @map("sales_officer_id") @db.Uuid
  createdById    String   @map("created_by_id") @db.Uuid
  totalAmount    Decimal  @db.Decimal(12, 2) @map("total_amount")
  amountPaid     Decimal? @db.Decimal(12, 2) @map("amount_paid")
  challanNumber  String?  @map("challan_number") @db.VarChar(16)
  notes          String?  @db.VarChar(1024)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  salesOfficer User             @relation("DirectSaleSalesOfficer", fields: [salesOfficerId], references: [id])
  createdBy    User             @relation("DirectSaleCreatedBy", fields: [createdById], references: [id])
  items        DirectSaleItem[]

  @@map("direct_sales")
}

model DirectSaleItem {
  id           String  @id @default(uuid()) @db.Uuid
  directSaleId String  @map("direct_sale_id") @db.Uuid
  productId    String  @map("product_id") @db.Uuid
  quantity     Int
  unitPrice    Decimal @db.Decimal(10, 2) @map("unit_price")

  directSale DirectSale @relation(fields: [directSaleId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])

  @@map("direct_sale_items")
}

model AppSetting {
  key         String   @id @db.VarChar(64)
  value       String   @db.VarChar(512)
  description String?  @db.VarChar(255)
  // Nullable to support seed-time inserts before any user exists
  updatedBy   String?  @map("updated_by") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  updatedByUser User? @relation(fields: [updatedBy], references: [id])

  @@map("app_settings")
}

// Append-only audit trail. entityId is VarChar (not UUID FK) so
// records survive soft-deletes of the referenced entity.
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String   @map("actor_id") @db.Uuid
  action     String   @db.VarChar(64)
  entityType String   @map("entity_type") @db.VarChar(64)
  entityId   String   @map("entity_id") @db.VarChar(64)
  diff       Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([entityType, entityId])
  @@index([actorId])
  @@map("audit_logs")
}
