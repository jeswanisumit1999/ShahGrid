# ShahGrid backend — SERVER .env  (copy to E:\apps\shahgrid\shared\.env)
# Read at runtime by dist/server.js via dotenv. update.ps1 copies this file
# into each new release's backend folder, so it survives version swaps.
#
# NOTE: the frontend does NOT read this file. The Flutter web build bakes its
# API URL at build time (--dart-define=API_BASE_URL=...). See release.ps1.

NODE_ENV=production
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Runtime: through pgBouncer (6432). pgbouncer=true disables prepared statements.
DATABASE_URL=postgresql://shahgrid:djsfklasjdfksdajf@127.0.0.1:6432/shahgrid?pgbouncer=true
# Migrations / prisma generate: DIRECT to Postgres (5432), bypassing the pooler.
DIRECT_DATABASE_URL=postgresql://shahgrid:djsfklasjdfksdajf@127.0.0.1:5432/shahgrid
# If you ever change the password to one containing @ : / etc., URL-encode it
# (e.g. @ -> %40) in BOTH urls above.

# ── JWT secrets (generate: openssl rand -base64 64) ───────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_min_32_chars_access_secret_xxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=CHANGE_ME_min_32_chars_refresh_secret_xxxxxxxxxxxxxxx
JWT_ACCESS_EXPIRES_IN=15d
JWT_REFRESH_EXPIRES_IN=30d

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=680536763427-jciqp6qtk5l16k3lba53qdhn0snhie0j.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_CALLBACK_URL=https://app.shahgrid.com/api/v1/auth/google/callback

# ── Frontend origin (CORS) ────────────────────────────────────────────────────
FRONTEND_URL=https://app.shahgrid.com
